// Firestore authorization for server-issued Firebase identities.
//
// The browser's localStorage role is never consulted. Supervisor and navigator
// identities are minted only by /api/supervisor-login and /api/navigator-login;
// custom claims drive every rule below.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSupervisor() {
      return signedIn() && request.auth.token.role == 'supervisor';
    }

    function isNavigator() {
      return signedIn() &&
        request.auth.token.role == 'navigator' &&
        request.auth.token.navigatorId is string;
    }

    function owns(data) {
      return isNavigator() && data.navigatorId == request.auth.token.navigatorId;
    }

    function ownerUnchanged() {
      return request.resource.data.navigatorId == resource.data.navigatorId;
    }


    // Result reads use direct document lookups. Firestore evaluates rules even
    // when the requested document does not exist, so resource.data cannot prove
    // ownership in that case. Permit only the exact result IDs the authenticated
    // navigator can own; this lets an unfinished assessment return "not found"
    // without granting access to another navigator's result.
    function isOwnResultDocId(docId) {
      return isNavigator() && (
        docId == request.auth.token.navigatorId ||
        docId == request.auth.token.navigatorId + '__pediatrics' ||
        docId == request.auth.token.navigatorId + '__pediatrics__spot' ||
        docId == request.auth.token.navigatorId + '__pediatrics__qa' ||
        docId == request.auth.token.navigatorId + '__obgyn' ||
        docId == request.auth.token.navigatorId + '__obgyn__spot' ||
        docId == request.auth.token.navigatorId + '__obgyn__qa'
      );
    }

    // PIN hashes and roster metadata never leave the supervisor/server boundary.
    match /roster/{docId} {
      allow read, create, update, delete: if isSupervisor();
    }

    match /results/{docId} {
      allow get: if isSupervisor() || owns(resource.data) || isOwnResultDocId(docId);
      allow list: if isSupervisor();
      allow create: if isSupervisor() || owns(request.resource.data);
      allow update: if isSupervisor() || (owns(resource.data) && owns(request.resource.data) && ownerUnchanged());
      allow delete: if isSupervisor();
    }

    // Navigator history is append-only; supervisors can read but do not rewrite it.
    match /resultHistory/{docId} {
      allow read: if isSupervisor() || owns(resource.data);
      allow create: if isSupervisor() || owns(request.resource.data);
      allow update, delete: if false;
    }

    // Navigators may fetch only the active assessment bank. All authoring states
    // and mutations stay supervisor-only.
    match /questions/{docId} {
      allow read: if isSupervisor() || (isNavigator() && resource.data.status == 'active');
      allow create, update, delete: if isSupervisor();
    }

    match /audits/{docId} {
      allow read: if isSupervisor() || (isNavigator() && resource.data.status == 'active');
      allow create, update, delete: if isSupervisor();
    }

    match /completions/{docId} {
      allow read: if isSupervisor() || owns(resource.data);
      allow create: if isSupervisor() || owns(request.resource.data);
      allow update, delete: if isSupervisor();
    }

    match /interviews/{docId} {
      allow read: if isSupervisor() || owns(resource.data);
      allow create: if isSupervisor() || owns(request.resource.data);
      // Navigators only attach the server-generated AI grade/QA payload. They
      // cannot rewrite transcripts, ownership, supervisor overrides, or final
      // review fields after the attempt is created.
      allow update: if isSupervisor() || (
        owns(resource.data) && owns(request.resource.data) && ownerUnchanged() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['grade', 'qa'])
      );
      allow delete: if isSupervisor();
    }

    match /pairings/{docId} {
      allow read, create, update, delete: if isSupervisor();
    }

    match /supervisorFeedback/{docId} {
      allow read, create, update, delete: if isSupervisor();
    }

    match /learningProposals/{docId} {
      allow read, create, update, delete: if isSupervisor();
    }

    match /sops/{docId} {
      allow read, create, update, delete: if isSupervisor();
    }

    // Transactional per-department active-SOP pointer.
    match /activeSops/{department} {
      allow read, create, update, delete: if isSupervisor();
    }

    match /contentMigrations/{docId} {
      allow read, create, update, delete: if isSupervisor();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
