# ─────────────────────────────────────────────────────────────────────────────
# Firebase config for the Quarterly Knowledge Check pilot.
#
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Add a Web App to the project (the </> icon) — no hosting needed.
# 3. Enable Firestore Database (Build → Firestore Database → Create, start in
#    test mode for the pilot, or use the rules in firestore.rules).
# 4. Copy the config values from Project Settings → Your apps → SDK setup.
# 5. Save this file as `.env.local` (NOT committed — it is gitignored) and fill
#    in the values below.
# 6. Restart `npm run dev` so Vite picks up the new env vars.
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Gemini scenario generation / coaching / roleplay / grading (server-side ONLY).
#
# These are NOT VITE_-prefixed on purpose: Vite never bundles them into the
# browser, so the key stays private. On Railway, set them as service Variables.
# For local dev through `node server.js`, put them in `.env.local`.
#
# - GEMINI_API_KEYS: one or more Google AI Studio keys
#   (https://aistudio.google.com/apikey), comma-separated. The server rotates to
#   the next key whenever one is rate-limited, maximising available quota.
#   (A single GEMINI_API_KEY is also accepted as a fallback.)
# - GEMINI_MODEL / GEMINI_LITE_MODEL: optional emergency overrides for the REST
#   Gemini model names used by api/_gemini-client.js. Leave blank in normal use;
#   defaults are current stable Gemini 3 models. If Google retires a model, set
#   these on Railway to hot-swap without a code change, then redeploy later.
# - GENERATION_SECRET: legacy shared secret (pre-hardening). Only used when
#   ALLOW_LEGACY_API_SECRET=true. Left unset in normal operation.
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEYS=
GEMINI_MODEL=
GEMINI_LITE_MODEL=
GENERATION_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Supervisor session (server-side authorization — 2026-07-08 pilot hardening).
#
# Supervisor-only authoring endpoints (/api/generate-scenarios, /api/refine-sop)
# now require a signed, HttpOnly session cookie issued by /api/supervisor-login.
# All values below are SERVER-ONLY (never VITE_-prefixed, never bundled).
#
# - SUPERVISOR_PASSCODE_SERVER: the passcode /api/supervisor-login validates.
#   PREFER setting this in production to a value that is NOT the public
#   src/data/config.js passcode. If unset, it falls back to
#   process.env.SUPERVISOR_PASSCODE, then to the bundled config value (so the
#   pilot / localhost works with no setup).
# - SESSION_SIGNING_SECRET: HMAC key for signing session tokens. Set a long random
#   value in production. If unset, a passcode-derived key is used (pilot fallback).
# - ALLOW_LEGACY_API_SECRET: set to `true` to also accept the old body.secret
#   value on protected endpoints (staged rollout / local tooling). Off by default.
# - REQUIRE_SUPERVISOR_SESSION: set to `true` to force a session on the
#   navigator/practice endpoints too. WARNING: this blocks navigator flows
#   (voice/chat practice, coaching, Call QA) — pilot toggle only.
# ─────────────────────────────────────────────────────────────────────────────
SUPERVISOR_PASSCODE_SERVER=
SESSION_SIGNING_SECRET=
ALLOW_LEGACY_API_SECRET=
REQUIRE_SUPERVISOR_SESSION=
