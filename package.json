{
  "name": "quarterly-knowledge-check",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Quarterly Knowledge Check prototype — capability map for patient navigators",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test tests/e2e/",
    "test:e2e:safe": "playwright test tests/e2e/",
    "test:e2e:deep": "playwright test \"(?<!tests/)e2e/\"",
    "test:e2e:all": "playwright test",
    "test:stress": "playwright test --config playwright.stress.config.js",
    "stress:quota": "node stress/quota-probe.mjs",
    "stress:voice": "node stress/voice-ws-probe.mjs",
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
